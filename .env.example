# Copy this file to .env and fill in real values for anything beyond local
# development. Core/settings.py falls back to safe development defaults if
# these are not set, so .env is optional for `runserver` on your own machine.

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key

# Must be "False" in any deployment reachable by anyone other than you.
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs allowed to serve this site,
# e.g. "example.com,www.example.com". Required when DJANGO_DEBUG=False.
DJANGO_ALLOWED_HOSTS=
